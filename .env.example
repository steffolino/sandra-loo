# Sandra Loo – Environment Variables
# Copy to .env and fill in the values.

# ============================================================
# Application
# ============================================================
APP_NAME="Sandra Loo"
APP_URL=http://localhost:3000

# Sub-path base URL for deployments served under a path prefix.
# For GitHub Pages: /sandra-loo/
# Leave empty (or /) for root deployments.
# NUXT_APP_BASE_URL=/

# ============================================================
# Database (optional – defaults to JSON files in data/imports/)
# ============================================================
# DATABASE_PATH=./data/sandra-loo.db

# ============================================================
# Data Import – OpenStreetMap
# ============================================================
# Overpass API endpoint (default: https://overpass-api.de/api/interpreter)
# OVERPASS_API=https://overpass-api.de/api/interpreter

# Comma-separated list of cities to import
# CITIES=Leipzig,Frankfurt am Main

# ============================================================
# Data Import – Leipzig Open Data
# ============================================================
# CKAN dataset slug (default: offentliche-toiletten-stadt-leipzig1)
# The import script uses this to auto-discover the CSV resource via
# the CKAN package_show API. You do not normally need to change this.
# LEIPZIG_DATASET_ID=offentliche-toiletten-stadt-leipzig1

# Base API URL (default: https://opendata.leipzig.de/api/3/action)
# LEIPZIG_API_URL=https://opendata.leipzig.de/api/3/action

# Optional: pin a specific CKAN resource ID to skip auto-discovery.
# Find it in the resource URL on: https://opendata.leipzig.de/dataset/offentliche-toiletten-stadt-leipzig1
# LEIPZIG_RESOURCE_ID=

# ============================================================
# Data Import – Frankfurt am Main Open Data
# ============================================================
# DKAN dataset slug (default: oeffentliche-wc-anlagen)
# FRANKFURT_DATASET_ID=oeffentliche-wc-anlagen

# DKAN/CKAN base API URL (default: https://www.offenedaten.frankfurt.de/api/3/action)
# FRANKFURT_API_URL=https://www.offenedaten.frankfurt.de/api/3/action

# Optional: direct GeoJSON / WFS endpoint to skip auto-discovery.
# Find it at: https://www.offenedaten.frankfurt.de/dataset/oeffentliche-wc-anlagen
# FRANKFURT_WFS_URL=
